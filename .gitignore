# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Local config overrides / secrets
.env
.env.*

# Keep folder structure, but ignore contents
raw/**
processed/*
reports/*
annotations/*

# Keep raw folder structure
!raw/
!raw/vacancies/
!raw/resumes/

# Ignore files inside raw subfolders
raw/vacancies/*
raw/resumes/*

# Keep placeholders
!raw/.gitkeep
!raw/vacancies/.gitkeep
!raw/resumes/.gitkeep
!processed/.gitkeep
!reports/.gitkeep
!annotations/.gitkeep

# Optional: keep README in annotations if you add one
!annotations/README.md

# Temporary files
*.log
*.tmp
*.bak